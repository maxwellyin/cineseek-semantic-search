{% extends "base.html" %}
{% block title %}CineSeek Results{% endblock %}

{% block content %}
<section class="page-card">
  <div class="row g-4">
    <div class="col-lg-5">
      <div class="eyebrow mb-3">Search Summary</div>
      <h1 class="section-title">Results for your query</h1>
      <p class="body-copy mb-4">{{ text }}</p>

      {% if query_used and query_used != text %}
      <div class="result-card mb-3">
        <div class="mini-label mb-2">Refined query</div>
        <div class="body-copy mb-0">{{ query_used }}</div>
      </div>
      {% endif %}

      {% if agent_enabled %}
      <div class="agent-note">
        <div class="eyebrow text-white-50 mb-2">LLM Agent</div>
        {% if agent_model %}
        <div class="mini-label text-white-50 mb-2">Backend: {{ agent_model }}</div>
        {% endif %}
        {% if agent_summary %}
        <p class="body-copy text-white-50 mb-0">{{ agent_summary|inline_markdown }}</p>
        {% endif %}
        {% if agent_error %}
        <p class="body-copy text-white-50 mb-0"><strong>Fallback:</strong> {{ agent_error }}</p>
        {% endif %}
      </div>
      {% endif %}

      <div class="mt-4">
        <a class="ghost-link" href="{{ url_for('search') }}">Run another search</a>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="eyebrow mb-3">Top Results</div>
      <div class="d-grid gap-3">
        {% for candidate in candidates %}
        <div class="result-card">
          <div class="d-flex align-items-center mb-2">
            <span class="result-rank">{{ loop.index }}</span>
            <h2 class="result-title">{{ candidate.title }}</h2>
          </div>

          <div class="mini-label mb-2">
            Relevance score: {{ "%.4f"|format(candidate.score) }}
          </div>

          {% set info = candidate.structured %}

          {% if info.overview %}
          <p class="body-copy mb-3">{{ info.overview }}</p>
          {% endif %}

          {% if info.genres %}
          <div class="mb-3">
            <div class="mini-label mb-2">Genres</div>
            <div class="d-flex flex-wrap gap-2">
              {% for genre in info.genres %}
              <span class="badge rounded-pill text-bg-light border">{{ genre }}</span>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          <div class="row g-3">
            {% if info.director %}
            <div class="col-md-6">
              <div class="mini-label mb-1">Director</div>
              <div class="body-copy mb-0">{{ info.director }}</div>
            </div>
            {% endif %}

            {% if info.actors %}
            <div class="col-md-6">
              <div class="mini-label mb-1">Actors</div>
              <div class="body-copy mb-0">{{ info.actors|join(", ") }}</div>
            </div>
            {% endif %}
          </div>

          {% if info.tags %}
          <div class="mt-3">
            <div class="mini-label mb-2">Tags</div>
            <div class="d-flex flex-wrap gap-2">
              {% for tag in info.tags %}
              <span class="badge rounded-pill" style="background: rgba(198, 93, 46, 0.12); color: var(--accent-dark); border: 1px solid rgba(198, 93, 46, 0.15);">{{ tag }}</span>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% endblock %}
